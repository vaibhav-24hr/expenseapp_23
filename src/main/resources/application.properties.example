#server port
server.port=9999

#view -- jsp
spring.mvc.view.prefix = /WEB-INF/views/
spring.mvc.view.suffix = .jsp

#DBconnection
spring.datasource.url=jdbc:mysql://localhost:3306/expenseapp
spring.datasource.username=YOUR_MYSQL_USERNAME
spring.datasource.password=YOUR_MYSQL_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

#Email (Gmail SMTP) used for Forgot-Password OTP
#Create a Gmail App Password from: https://myaccount.google.com/apppasswords
app.mail.from=your-email@gmail.com
app.mail.app-password=your-16-character-app-password
